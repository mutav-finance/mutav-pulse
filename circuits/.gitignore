# Regenerable ZK artifacts (heavy) — do NOT version.
# Reconstructible with the plan's toolchain (circom + snarkjs) from the .circom + .mjs.
node_modules/
# witness calculators generated by circom
*_js/
# powers-of-tau (~25-75 MB)
*.ptau
# proving keys (~19 MB)
*.zkey
# binary witnesses
*.wtns
# constraint systems
*.r1cs
# symbol tables
*.sym
# large debug dumps
witness.json
sb_witness.json

# Versioned (source + lightweight proof evidence):
#   *.circom, gen_input.mjs, package.json, package-lock.json
#   proof.json, public.json, verification_key.json  (judges run `snarkjs groth16 verify`)
#   *_input.json  (example inputs)
